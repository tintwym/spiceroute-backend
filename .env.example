# Database — choose ONE.
# Local Docker Postgres (requires `docker compose --profile local-db up`):
DATABASE_URL=postgresql+asyncpg://spiceroute:spiceroute@db:5432/spiceroute
# Neon (managed Postgres). Use the `?ssl=require` query param (asyncpg, not libpq):
# DATABASE_URL=postgresql+asyncpg://USER:PASS@ep-xxx.REGION.aws.neon.tech/DBNAME?ssl=require

# JWT
JWT_SECRET=change-me-to-a-long-random-string-in-real-deployments
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=30

# Storage
IMAGE_STORAGE_DIR=/var/spiceroute-images
PUBLIC_IMAGE_BASE_URL=http://localhost:8000/images
MAX_IMAGE_BYTES=5242880

# CORS (comma-separated). Use "*" for local dev.
CORS_ORIGINS=*

# App
APP_NAME=SpiceRoute API
DEBUG=true
