# Database — choose ONE.
# Local Docker Postgres (requires `docker compose --profile local-db up`):
DATABASE_URL=postgresql+asyncpg://spiceroute:spiceroute@db:5432/spiceroute
# Neon (managed Postgres). Use the `?ssl=require` query param (asyncpg, not libpq):
# DATABASE_URL=postgresql+asyncpg://USER:PASS@ep-xxx.REGION.aws.neon.tech/DBNAME?ssl=require

# Google Gemini — leave blank to run in stub mode (deterministic mock responses,
# useful for local development). Grab a real key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# AI rate limits per client IP
AI_RATE_LIMIT_PER_DAY=30
AI_CHAT_PER_HOUR=50

# Firebase Admin — TWO ways to provide credentials, pick one:
#
#  (a) Path to a service-account JSON on disk (best locally — drop the
#      file at the repo root and forget about it).
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json
#
#  (b) The same JSON inlined as a single string (best on hosted
#      platforms — Fly.io, Render, Railway, where you set this via
#      `fly secrets set FIREBASE_CREDENTIALS_JSON="$(cat …)"` or the
#      dashboard's env editor). Takes precedence over (a) when set.
# FIREBASE_CREDENTIALS_JSON=
#
# When NEITHER resolves, the backend runs in DEV MODE and accepts
# tokens of the form "dev:<uid>" — useful for tests and offline dev.

# CORS (comma-separated). Use "*" for local dev.
CORS_ORIGINS=*

# App
APP_NAME=Savor Global Recipes API
DEBUG=true

CORS_ORIGINS=https://your-app.vercel.app,https://*.vercel.app